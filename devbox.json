{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": [
    "python@3.12",
    "icoutils@latest",
    "wget@latest",
    "mesa@latest",
    "zstd@latest",
    "libxkbcommon@latest",
    "fontconfig@latest",
    "freetype@latest",
    "libxcb@latest",
    "libxcb-cursor@latest",
    "libxcb-keysyms@latest",
    "libxcb-wm@latest",
    "dbus@latest",
    "glib@latest",
    "xorg.libX11@latest",
    "libglvnd@latest",
    "patchelf@latest"
  ],
  "shell": {
    "init_hook": [
      ". \"$DEVBOX_PROJECT_ROOT/.devbox/lib-path.sh\"",
      ". \"$VENV_DIR/bin/activate\""
    ],
    "scripts": {
      "install": "python3 -m pip install -r requirements.txt -r requirements-dev.txt",
      "test": "pytest tests/",
      "build": "./build.sh",
      "run": "PYTHONPATH=python python3 -m crucible"
    }
  }
}
